{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "lib": [
            "ES2023"
        ],
        "outDir": "./dist-server",
        "rootDir": "./server",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "types": [
            "node"
        ],
        "noEmit": false,
        "allowImportingTsExtensions": false
    },
    "include": [
        "server/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "src",
        "dist",
        "dist-server"
    ]
}